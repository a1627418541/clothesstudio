# Required
DATABASE_URL="postgresql://user:password@host:5432/db?sslmode=require"
AUTH_SECRET="your-random-auth-secret-min-32-chars"
AUTH_URL="http://localhost:3000"

# Optional: Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Optional: Resend Magic Link
AUTH_RESEND_KEY=""
EMAIL_FROM="AI Personal Style Studio <no-reply@example.com>"

# Required for uploads and durable style previews: Cloudflare R2
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET_NAME=""
# Must be an absolute, browser-accessible HTTP(S) base URL.
CLOUDFLARE_R2_PUBLIC_BASE_URL="https://pub-xxx.r2.dev"

# Reserved: Inngest (not used in Sprint 1)
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Reserved: PostHog (not used in Sprint 1)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# AI Provider — Text diagnosis (server-side only)
# Options: openai | mock | gemini
# Use an OpenAI-compatible endpoint such as StarAPI or OpenAI official.
AI_PROVIDER="openai"
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_STYLE_MODEL="gpt-4o-mini"

# Style Preview Image Provider — Image generation for recommendations (server-side only)
# Options: openai | mock
# Uses a separate API key/base URL from text diagnosis so you can point image
# generation at OpenAI or EvoLink while text diagnosis runs through a separate
# OpenAI-compatible provider.
STYLE_PREVIEW_PROVIDER="mock"
STYLE_PREVIEW_MODEL="gpt-image-2"
STYLE_PREVIEW_OPENAI_API_KEY=""
# EvoLink: https://api.evolink.ai/v1
STYLE_PREVIEW_OPENAI_BASE_URL="https://api.openai.com/v1"
STYLE_PREVIEW_FALLBACK_TO_MOCK="false"

# Domestic virtual try-on benchmark only (server-side; never commit real values)
TENCENT_CLOUD_SECRET_ID=""
TENCENT_CLOUD_SECRET_KEY=""
TENCENT_CLOUD_REGION="ap-guangzhou"
VOLCENGINE_ACCESS_KEY_ID=""
VOLCENGINE_SECRET_ACCESS_KEY=""
VOLCENGINE_REGION="cn-beijing"
