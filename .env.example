# Required
DATABASE_URL="postgresql://user:password@host:5432/db?sslmode=require"
AUTH_SECRET="your-random-auth-secret-min-32-chars"
AUTH_URL="http://localhost:3000"

# Optional: Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Optional: Resend Magic Link
AUTH_RESEND_KEY=""
EMAIL_FROM="AI Personal Style Studio <no-reply@example.com>"

# Optional: Cloudflare R2 (server-side upload)
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET_NAME=""
CLOUDFLARE_R2_PUBLIC_BASE_URL="https://pub-xxx.r2.dev"

# Reserved: Inngest (not used in Sprint 1)
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Reserved: PostHog (not used in Sprint 1)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# AI Provider (server-side only)
# Options: openai | mock | gemini
AI_PROVIDER="openai"
OPENAI_API_KEY=""
OPENAI_STYLE_MODEL="gpt-4o-mini"
OPENAI_BASE_URL=""

# Style Preview Image Provider (server-side only)
# Options: openai | mock
STYLE_PREVIEW_PROVIDER="mock"
STYLE_PREVIEW_MODEL="gpt-image-2"
STYLE_PREVIEW_FALLBACK_TO_MOCK="false"
